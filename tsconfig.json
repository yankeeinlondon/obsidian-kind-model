{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ESNext",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"strictNullChecks": true,
		"types": [
			"obsidian"
		],
		"typeRoots": [
			"node_modules/@types",
			"node_modules/obsidian"
		],
		"paths": {
			"~/*": [
				"./src/*"
			],
			"test/*": [
				"./test/*"
			]
		},
		"lib": [
			"DOM",
			"ES5",
			"ES6",
			"ES7",
			"ES2022"
		]
	},
	"include": [
		"src",
		"test"
	],
	"exclude": [
		"node_modules",
		"dist",
		"*.mjs"
	]
}
